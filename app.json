{
  "expo": {
    "name": "游戏监控",
    "slug": "game-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gamemonitor.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4CAF50"
      },
      "package": "com.gamemonitor.app",
      "permissions": [
        "SYSTEM_ALERT_WINDOW",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [],
    "extra": {
      "eas": {
        "projectId": "82267b63-30b5-42b2-9109-84d31d481eb3"
      }
    }
  }
}
